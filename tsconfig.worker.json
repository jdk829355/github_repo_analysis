{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "workers/**/*.ts",
    "lib/**/*.ts",
    "services/**/*.ts",
    "schemas/**/*.ts",
    "prompts/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist", "tests", "app", "components"]
}
